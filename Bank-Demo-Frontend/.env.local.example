# ==========================================
# 🖥️ VİTRİN (NEXT.JS) - ÖRNEK ÇEVRE DEĞİŞKENLERİ
# Not: Bu dosyayı '.env.local' olarak kopyalayın ve gizli anahtarları doldurun.
# ==========================================

# 🚀 BUKALEMUN ADRESİ: Frontend ve API Gateway Nginx (HTTPS) Adresleri
NEXT_PUBLIC_FRONTEND_URL=https://app.bank.local
NEXT_PUBLIC_API_URL=https://api.bank.local/api/v1

# 🔐 KEYCLOAK AYARLARI
NEXT_PUBLIC_KEYCLOAK_URL=https://auth.bank.local
KEYCLOAK_REALM=bank-realm
KEYCLOAK_CLIENT_ID=bank-auth-client

# Docker içinden Keycloak'a erişim adresi (Standarttır, değiştirmeyin)
KEYCLOAK_INTERNAL_URL=http://keycloak:8080

# Keycloak panelinden alınan Client Secret (Backend ile AYNI olmak zorundadır!)
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret_here

# 🤖 GOOGLE RECAPTCHA (Frontend için Public Site Key)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_google_recaptcha_site_key_here